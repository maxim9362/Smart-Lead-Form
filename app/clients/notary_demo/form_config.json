{
  "client_id": "notary_demo",
  "scenario_key": "notary_request",
  "version": "1.0",
  "language": "ru",
  "title": "Заявка на нотариальную услугу",
  "description": "Ответьте на несколько вопросов, и нотариус свяжется с вами для уточнения деталей.",
  "steps": [
    {
      "key": "service_type",
      "question": "Какая нотариальная услуга вам нужна?",
      "type": "single_choice",
      "required": true,
      "options": [
        {
          "label": "Нотариальный перевод",
          "value": "notary_translation"
        },
        {
          "label": "Заверение подписи",
          "value": "signature_verification"
        },
        {
          "label": "Доверенность",
          "value": "power_of_attorney"
        },
        {
          "label": "Аффидевит / декларация",
          "value": "affidavit"
        },
        {
          "label": "Копия документа",
          "value": "document_copy"
        },
        {
          "label": "Апостиль",
          "value": "apostille"
        },
        {
          "label": "Консультация",
          "value": "consultation"
        },
        {
          "label": "Другое",
          "value": "other"
        }
      ]
    },
    {
      "key": "language_pair",
      "question": "С какого языка и на какой нужен перевод?",
      "type": "single_choice",
      "required": false,
      "show_if": {
        "key": "service_type",
        "equals": "notary_translation"
      },
      "options": [
        {
          "label": "Русский → Иврит",
          "value": "ru_he"
        },
        {
          "label": "Иврит → Русский",
          "value": "he_ru"
        },
        {
          "label": "Английский → Иврит",
          "value": "en_he"
        },
        {
          "label": "Иврит → Английский",
          "value": "he_en"
        },
        {
          "label": "Другой вариант",
          "value": "other"
        }
      ]
    },
    {
      "key": "page_count",
      "question": "Сколько примерно страниц в документе?",
      "type": "single_choice",
      "required": false,
      "show_if_any": [
        {
          "key": "service_type",
          "equals": "notary_translation"
        },
        {
          "key": "service_type",
          "equals": "document_copy"
        }
      ],
      "options": [
        {
          "label": "1 страница",
          "value": "1"
        },
        {
          "label": "2–3 страницы",
          "value": "2_3"
        },
        {
          "label": "4–10 страниц",
          "value": "4_10"
        },
        {
          "label": "Больше 10 страниц",
          "value": "10_plus"
        },
        {
          "label": "Пока не знаю",
          "value": "unknown"
        }
      ]
    },
    {
      "key": "urgency",
      "question": "Насколько срочно нужна услуга?",
      "type": "single_choice",
      "required": true,
      "options": [
        {
          "label": "Сегодня",
          "value": "today"
        },
        {
          "label": "В течение 1–2 дней",
          "value": "1_2_days"
        },
        {
          "label": "На этой неделе",
          "value": "this_week"
        },
        {
          "label": "Не срочно",
          "value": "not_urgent"
        }
      ]
    },
    {
      "key": "meeting_format",
      "question": "Как вам удобнее продолжить?",
      "type": "single_choice",
      "required": true,
      "options": [
        {
          "label": "Прийти в офис",
          "value": "office"
        },
        {
          "label": "Сначала консультация по телефону",
          "value": "phone"
        },
        {
          "label": "Онлайн-консультация",
          "value": "online"
        }
      ]
    },
    {
      "key": "city",
      "question": "В каком городе вы находитесь?",
      "type": "single_choice",
      "required": true,
      "options": [
        {
          "label": "Ашдод",
          "value": "ashdod"
        },
        {
          "label": "Ашкелон",
          "value": "ashkelon"
        },
        {
          "label": "Тель-Авив",
          "value": "tel_aviv"
        },
        {
          "label": "Ришон-ле-Цион",
          "value": "rishon_lezion"
        },
        {
          "label": "Иерусалим",
          "value": "jerusalem"
        },
        {
          "label": "Другой город",
          "value": "other"
        }
      ]
    },
    {
      "key": "documents_ready",
      "question": "Документы уже готовы?",
      "type": "single_choice",
      "required": true,
      "options": [
        {
          "label": "Да, документы на руках",
          "value": "ready"
        },
        {
          "label": "Есть фото или скан",
          "value": "scan"
        },
        {
          "label": "Нет, нужна консультация",
          "value": "need_consultation"
        },
        {
          "label": "Не уверен",
          "value": "not_sure"
        }
      ]
    },
    {
      "key": "name",
      "question": "Как вас зовут?",
      "type": "text",
      "required": true,
      "placeholder": "Например: Максим"
    },
    {
      "key": "phone",
      "question": "Ваш телефон?",
      "type": "phone",
      "required": true,
      "placeholder": "Например: 0541234567"
    },
    {
      "key": "email",
      "question": "Email, если удобно получить ответ письмом",
      "type": "email",
      "required": false,
      "placeholder": "example@email.com"
    },
    {
      "key": "preferred_contact_time",
      "question": "Когда удобно связаться?",
      "type": "text",
      "required": true,
      "placeholder": "Например: сегодня после 13:00"
    },
    {
      "key": "comment",
      "question": "Комментарий, если хотите что-то добавить",
      "type": "textarea",
      "required": false,
      "placeholder": "Например: нужен перевод свидетельства о рождении"
    }
  ]
}
